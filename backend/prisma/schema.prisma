generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "windows"]
  engineType    = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid()) @db.Uuid
  firstName         String             @map("first_name")
  lastName          String             @map("last_name")
  email             String             @unique
  phone             String?
  hashedPassword    String             @map("hashed_password")
  role              UserRole
  rating            Int?
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  tournamentAdmins  TournamentAdmin[]
  tournamentPlayers TournamentPlayer[]

  @@map("user")
}

model Tournament {
  id                String             @id @default(uuid()) @db.Uuid
  name              String
  format            TournamentFormat
  location          String?
  timeControl       String             @map("time_control")
  totalRounds       Int?               @map("total_rounds")
  category          String?
  tournamentType    TournamentType     @default(SINGLE) @map("tournament_type")
  startDate         DateTime           @map("start_date") @db.Date
  endDate           DateTime?          @map("end_date") @db.Date
  published         Boolean            @default(false)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  rounds            Round[]
  tournamentAdmins  TournamentAdmin[]
  tournamentPlayers TournamentPlayer[]

  @@map("tournament")
}

model Round {
  id           String     @id @default(uuid()) @db.Uuid
  tournamentId String     @map("tournament_id") @db.Uuid
  roundNumber  Int        @map("round_number")
  title        String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  matches      Match[]
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, roundNumber])
  @@map("round")
}

model Match {
  id                String             @id @default(uuid()) @db.Uuid
  roundId           String             @map("round_id") @db.Uuid
  player1Id         String?            @map("player1_id") @db.Uuid
  player2Id         String?            @map("player2_id") @db.Uuid
  winnerPlayerId    String?            @map("winner_player_id") @db.Uuid
  nextMatchId       String?            @map("next_match_id") @db.Uuid
  nextMatchPosition NextMatchPosition? @map("next_match_position")
  scheduledAt       DateTime?          @map("scheduled_at")
  startedAt         DateTime?          @map("started_at")
  finishedAt        DateTime?          @map("finished_at")
  player1Score      Decimal?           @map("player1_score") @db.Decimal(2, 1)
  player2Score      Decimal?           @map("player2_score") @db.Decimal(2, 1)
  player1Color      ChessColor?        @map("player1_color")
  player2Color      ChessColor?        @map("player2_color")
  status            MatchStatus        @default(PENDING)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  nextMatch         Match?             @relation("MatchProgression", fields: [nextMatchId], references: [id])
  previousMatches   Match[]            @relation("MatchProgression")
  player1           TournamentPlayer?  @relation("MatchPlayer1", fields: [player1Id], references: [id])
  player2           TournamentPlayer?  @relation("MatchPlayer2", fields: [player2Id], references: [id])
  round             Round              @relation(fields: [roundId], references: [id], onDelete: Cascade)
  winner            TournamentPlayer?  @relation("MatchWinner", fields: [winnerPlayerId], references: [id])

  @@map("match")
}

model TournamentPlayer {
  id               String                 @id @default(uuid()) @db.Uuid
  tournamentId     String                 @map("tournament_id") @db.Uuid
  userId           String                 @map("user_id") @db.Uuid
  status           TournamentPlayerStatus @default(REGISTERED)
  seedNumber       Int?                   @map("seed_number")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  matchesAsPlayer1 Match[]                @relation("MatchPlayer1")
  matchesAsPlayer2 Match[]                @relation("MatchPlayer2")
  matchesWon       Match[]                @relation("MatchWinner")
  tournament       Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@map("tournament_player")
}

model TournamentAdmin {
  id           String     @id @default(uuid()) @db.Uuid
  tournamentId String     @map("tournament_id") @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@map("tournament_admin")
}

enum TournamentFormat {
  ONLINE
  OFFLINE
}

enum TournamentType {
  SINGLE
  ROUND_ROBIN
  DOUBLE_ELIMINATION
  SWISS
}

enum UserRole {
  ADMIN
  PLAYER
}

enum TournamentPlayerStatus {
  REGISTERED
  ELIMINATED
  WINNER
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  NEEDS_TIEBREAK
}

enum NextMatchPosition {
  TOP
  BOTTOM
}

enum ChessColor {
  WHITE
  BLACK
}
